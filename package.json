{
  "name": "@wagent/wagent",
  "version": "0.2.37",
  "description": "WAGENT - WhatsApp AI Agent Platform",
  "type": "module",
  "main": "./bin/wagent",
  "bin": {
    "wagent": "./bin/wagent"
  },
  "files": [
    "packages/*/dist/**",
    "prompts/**",
    "schemas/**",
    "bin/wagent",
    "bin/wagent.service",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "cd packages/core && bun run build && cd ../dashboard && bun run build && cd ../tui && bun run build && cd ../whatsapp && bun run build && cd ../cli && bun run build",
    "publish:root": "node scripts/publish-root.mjs",
    "prepublishOnly": "npm run build",
    "start": "./bin/wagent start",
    "dev": "./bin/wagent start --no-dashboard",
    "test": "cd packages/core && npx vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist node_modules",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@wagent/core": "latest",
    "@wagent/cli": "latest",
    "@wagent/whatsapp": "latest",
    "@wagent/tui": "latest",
    "@wagent/dashboard": "latest"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "chatbot",
    "customer-service",
    "baileys",
    "agent",
    "automation"
  ],
  "author": "crediblemark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crediblemark-official/WAGENT.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7"
  }
}