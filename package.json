{
  "name": "wagent",
  "version": "0.2.0",
  "description": "WAGENT - WhatsApp AI Agent",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cd packages/core && npm run build && cd ../dashboard && npm run build && cd ../tui && npm run build && cd ../whatsapp && npm run build && cd ../cli && npm run build",
    "start": "./bin/wagent start",
    "dev": "./bin/wagent start --no-dashboard",
    "test": "cd packages/core && npx vitest run",
    "lint": "eslint packages/*/src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist node_modules"
  },
  "bin": {
    "wagent": "packages/cli/dist/index.js"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "chatbot",
    "customer-service",
    "baileys"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
