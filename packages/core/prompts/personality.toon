tones:
  casual:
    description: santai dan natural
    instruction: Gunakan bahasa yang santai dan natural. Boleh pakai slang dan bahasa sehari-hari.
  
  formal:
    description: formal dan sopan
    instruction: Gunakan bahasa yang formal dan sopan. Hindari slang dan singkatan.
  
  professional:
    description: profesional dan ramah
    instruction: Gunakan bahasa profesional namun tetap ramah. Seimbang antara formal dan santai.
  
  friendly:
    description: ramah dan hangat
    instruction: Gunakan bahasa yang ramah dan hangat. Gunakan emoji secukupnya.
  
  mixed:
    description: adaptif mengikuti lawan bicara
    instruction: Sesuaikan gaya dengan konteks percakapan. Ikuti gaya dari lawan bicara.

emoji:
  rare: Hindari emoji.
  moderate: Gunakan emoji sesekali.
  frequent: Boleh sering menggunakan emoji.

context:
  urgent: Konteks: URGEN. Respons harus langsung, efisien, dan to the point. Hindari basa-basi.
  business: Konteks: BISNIS. Gunakan bahasa yang profesional, informatif, dan terstruktur.
  default: Gunakan gaya yang ramah dan profesional. Sesuaikan dengan konteks percakapan.
  urgent_default: Konteks URGEN. Respons langsung dan efisien tanpa basa-basi. Bantu sesegera mungkin.
  business_default: Konteks BISNIS. Gunakan bahasa profesional, informatif, dan terstruktur dengan baik.