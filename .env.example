# === OpenCS Configuration ===

# WhatsApp Session Name
WHATSAPP_SESSION_NAME=opencs-session

# AI Provider (openai, gemini, claude, ollama)
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# System Prompt for AI Agent
AGENT_SYSTEM_PROMPT="Kamu adalah customer service yang ramah dan membantu."

# Dashboard
DASHBOARD_PORT=3030
DASHBOARD_HOST=localhost

# Escalation to Telegram (when AI can't answer)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234...
# TELEGRAM_CHAT_ID=-123456789

# Human Takeover (AI stops replying when human replies)
# HUMAN_TAKEOVER_COOLDOWN_MINUTES=30

# Knowledge Base
# AGENT_KNOWLEDGE_BASE_ENABLED=true
# AGENT_KNOWLEDGE_BASE_MAX_RESULTS=3

# Database (sqlite | postgres)
DATABASE_TYPE=sqlite
DATABASE_URL=./data/opencs.db
